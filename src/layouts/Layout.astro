---
import '../global.css';
interface Props {
	title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="ja" data-theme="light">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
	</head>
	<body class="min-h-screen bg-base-200">
		<header class="navbar bg-base-100 shadow-lg px-4">
			<div class="flex-1">
				<a href="/" class="text-2xl font-black tracking-tighter hover:opacity-80 transition-opacity">
					<span class="text-primary">Code</span>Gakko <span class="badge badge-outline badge-sm font-mono">Proto</span>
				</a>
			</div>
		</header>
		<slot />
	</body>
</html>